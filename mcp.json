{
  "mcpServers": {
    "visualq": {
      "command": "npx",
      "args": ["-y", "@visualq/mcp"],
      "env": {
        "VISUALQ_API_KEY": "${VISUALQ_API_KEY}",
        "VISUALQ_BASE_URL": "https://visualq.ai",
        "VISUALQ_DEFAULT_PROJECT": "${VISUALQ_DEFAULT_PROJECT}",
        "VISUALQ_TOOL_PROFILE": "${VISUALQ_TOOL_PROFILE}"
      }
    }
  }
}
